{
  "openapi": "3.0.4",
  "info": {
    "title": "TDMK IoT API - Hoang Thai Thuy",
    "description": "API hệ thống tracking ảnh và số liệu Realtime",
    "version": "v1"
  },
  "paths": {
    "/api/Telemetry": {
      "post": {
        "tags": [
          "Telemetry"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "Value": {
                    "type": "number",
                    "format": "double"
                  },
                  "Image": {
                    "type": "string",
                    "format": "binary"
                  },
                  "DeviceId": {
                    "type": "string"
                  }
                }
              },
              "encoding": {
                "Value": {
                  "style": "form"
                },
                "Image": {
                  "style": "form"
                },
                "DeviceId": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Telemetry/reports": {
      "get": {
        "tags": [
          "Telemetry"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Telemetry/{id}": {
      "get": {
        "tags": [
          "Telemetry"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": { },
  "tags": [
    {
      "name": "Telemetry"
    }
  ]
}